@model BlogApp.Models.BlogViewModel

<div class="container-fluid py-5">
    <div class="row justify-content-center">

        <div class="col-md-3 col-lg-2 pe-md-0" style="max-width: 280px;">

            <vc:categories-menu></vc:categories-menu>

            <vc:last-posts></vc:last-posts>
        </div>


        <div class="col-md-9 col-lg-9 col-xl-9 ps-md-4">

            @if (ViewBag.SelectedCategory != null)
            {
                <div class="alert alert-light border mb-4">
                    <h4 class="mb-0">
                        <i class="bi bi-tag me-2"></i> @ViewBag.SelectedCategory.CategoryName
                    </h4>
                </div>
            }
            else
            {
                <h1 class="text-center mb-4">Tüm Blog Yazıları</h1>
            }


            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var blog in Model.Blogs)
                {
                    <div class="col">
                        <div class="card shadow-sm h-100" style="min-height: 500px;">
                            <img src="~/img/blogs/@blog.Image" class="card-img-top" alt="@blog.Title" style="height: 220px; object-fit: cover;">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@blog.Title</h5>
                                <div class="mb-2">
                                    <a asp-controller="Blog" asp-action="Category" asp-route-url="@blog.Category.Url"
                                       class="badge bg-@blog.Category.Color text-decoration-none">
                                        @blog.Category.CategoryName
                                    </a>
                                </div>
                                <p class="card-text flex-grow-1">@blog.Description.Substring(0, Math.Min(blog.Description.Length, 100))...</p>
                            </div>
                            <div class="card-footer bg-white border-top-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">@blog.CreatedDate.ToString("dd MMMM yyyy")</small>
                                    <a href="/blog/@blog.Url" class="btn btn-sm btn-outline-primary">Devamını Oku</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>


            @if (Model.TotalPage > 1)
            {
                <div class="d-flex justify-content-center mt-5">
                    <nav aria-label="Blog Sayfaları">
                        <ul class="pagination">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                @if (ViewBag.SelectedCategory != null)
                                {
                                    <a class="page-link" asp-controller="Blog" asp-action="Category"
                                       asp-route-url="@ViewBag.SelectedCategory.Url"
                                       asp-route-pageNumber="@(Model.CurrentPage - 1)">
                                        <span>&laquo;</span>
                                    </a>
                                }
                                else
                                {
                                    <a class="page-link" asp-controller="Blog" asp-action="Index"
                                       asp-route-pageNumber="@(Model.CurrentPage - 1)">
                                        <span>&laquo;</span>
                                    </a>
                                }
                            </li>
                            <li class="page-item active">
                                <span class="page-link">
                                    Sayfa @Model.CurrentPage / @Model.TotalPage
                                </span>
                            </li>
                            <li class="page-item @(Model.CurrentPage == Model.TotalPage ? "disabled" : "")">
                                @if (ViewBag.SelectedCategory != null)
                                {
                                    <a class="page-link" asp-controller="Blog" asp-action="Category"
                                       asp-route-url="@ViewBag.SelectedCategory.Url"
                                       asp-route-pageNumber="@(Model.CurrentPage + 1)">
                                        <span>&raquo;</span>
                                    </a>
                                }
                                else
                                {
                                    <a class="page-link" asp-controller="Blog" asp-action="Index"
                                       asp-route-pageNumber="@(Model.CurrentPage + 1)">
                                        <span>&raquo;</span>
                                    </a>
                                }
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>