@model BlogApp.Models.BlogCreateModel

@{
    ViewData["Title"] = "Yeni BLog Yazısı Ekle";
    var returnUrl = ViewData["ReturnUrl"] as string;
    var isSuccess = TempData["BlogCreateSucces"] != null;
}


<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Yeni Blog Yazısı Oluştur</h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                        </div>
                    }

                    <form asp-controller="Blog" asp-action="CreateBlog" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Blog yazınızın başlığını girin" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Blog yazınızın kısa açıklamasını girin"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Url" class="form-label fw-bold"></label>
                            <div class="input-group">
                                <span class="input-group-text text-muted">blog/</span>
                                <input asp-for="Url" class="form-control" placeholder="blog-baslik-url" />
                            </div>
                            <span asp-validation-for="Url" class="text-danger"></span>
                            <div class="form-text text-muted">
                                <i class="bi bi-info-circle me-1"></i>URL'de Türkçe karakter, boşluk ve özel karakterler kullanmayın. Örnek: blog-yazisi-baslik
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold">Kategori</label>
                            <div class="input-group">
                                <select asp-for="CategoryId" class="form-select" id="categorySelect">
                                    <option value="">-- Kategori Seçin --</option>
                                    @if (Model.Categories != null)
                                    {
                                        foreach (var category in Model.Categories)
                                        {
                                            <option value="@category.CategoryId">@category.CategoryName</option>
                                        }
                                    }
                                </select>

                            </div>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>



                        <div class="mb-3">
                            <label asp-for="Content" class="form-label fw-bold"></label>
                            <textarea asp-for="Content" id="content-editor" class="form-control" rows="15" placeholder="Blog yazınızın içeriğini buraya girin"></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Image" class="form-label fw-bold">Blog Görseli</label>
                            <input asp-for="Image" type="file" class="form-control" accept="image/*" />

                        </div>



                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-controller="Blog" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Vazgeç
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Blog Yazısını Yayımla
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script src="~/lib/tinymce/tinymce.min.js"></script>


    <script>
        document.addEventListener('DOMContentLoaded', function () {
            tinymce.init({
                selector: '#content-editor',
                height: 500,
                plugins: [
                    'advlist', 'autolink', 'lists', 'link', 'image', 'charmap', 'preview',
                    'anchor', 'searchreplace', 'visualblocks', 'code', 'fullscreen',
                    'insertdatetime', 'media', 'table', 'help', 'wordcount'
                ],
                toolbar: 'undo redo | blocks | ' +
                    'bold italic backcolor | alignleft aligncenter ' +
                    'alignright alignjustify | bullist numlist outdent indent | ' +
                    'removeformat | help',
                content_style: 'body { font-family:Helvetica,Arial,sans-serif; font-size:16px }',
                branding: false,
                promotion: false,
                menubar: 'file edit view insert format tools table help',
                language: 'tr'
            });

            const titleInput = document.querySelector('#Title');
            const urlInput = document.querySelector('#Url');

            titleInput.addEventListener('blur', function () {
                if (urlInput.value === '') {
                    const title = titleInput.value;
                    const url = generateSlug(title);
                    urlInput.value = url;
                }
            });

            function generateSlug(text) {
                return text
                    .toString()
                    .toLowerCase()
                    .trim()
                    .replace(/ğ/g, 'g').replace(/ü/g, 'u').replace(/ş/g, 's')
                    .replace(/ı/g, 'i').replace(/ö/g, 'o').replace(/ç/g, 'c')
                    .replace(/\s+/g, '-')
                    .replace(/[^\w\-]+/g, '')
                    .replace(/\-\-+/g, '-')
                    .replace(/^-+/, '')
                    .replace(/-+$/, '');
            }

            document.querySelector('form').addEventListener('submit', function (e) {
                const categorySelect = document.getElementById('categorySelect');
                if (!categorySelect.value) {
                    e.preventDefault();
                    alert('Lütfen bir kategori seçin veya yeni bir kategori ekleyin.');
                }
            });
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
