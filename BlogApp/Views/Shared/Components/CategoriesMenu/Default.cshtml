@model IEnumerable<BlogApp.Entities.Category>
<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Kategoriler</h5>
    </div>
    <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
        <a asp-controller="Blog" asp-action="Index"
           class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.RouteData.Values["categoryId"] == null ? "active" : "")">
            Tüm Yazılar
        </a>
        @foreach (var category in Model)
        {
            <a asp-controller="Blog" asp-action="Category" asp-route-url="@category.Url"
               class="list-group-item list-group-item-action
                          d-flex justify-content-between align-items-center
                          @(ViewContext.RouteData.Values["url"]?.ToString() == category.Url ? "active" : "")">
                <span>
                    <i class="bi bi-tag-fill text-@category.Color.ToString() me-2"></i>
                    @category.CategoryName
                </span>
                <span class="badge bg-@category.Color.ToString()   rounded-pill">
                    @(ViewBag.CategoryBlogCounts != null && ViewBag.CategoryBlogCounts.ContainsKey(category.CategoryId) ?
                                    ViewBag.CategoryBlogCounts[category.CategoryId] : 0)
            </span>
        </a>
                }
    </div>
</div>