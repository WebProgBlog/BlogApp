  "components": {
    "schemas": {
      "Blog": {
        "required": [
          "categoryId",
          "content",
          "title",
          "url",
          "userId"
        ],
        "type": "object",
        "properties": {
          "blogId": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "maxLength": 200,
            "minLength": 5,
            "type": "string"
          },
          "content": {
            "minLength": 10,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          },
          "updatedDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "image": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "maxLength": 200,
            "minLength": 0,
            "pattern": "^[a-zA-Z0-9-_]+$",
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          },
