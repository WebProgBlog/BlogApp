            "type": "integer",
            "format": "int32"
          },
          "categoryName": {
            "maxLength": 100,
            "minLength": 2,
            "type": "string"
          },
          "description": {
            "maxLength": 500,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "categoryImage": {
            "type": "string",
            "nullable": true
          },
          "url": {
            "maxLength": 200,
            "minLength": 0,
            "pattern": "^[a-zA-Z0-9-_]+$",
