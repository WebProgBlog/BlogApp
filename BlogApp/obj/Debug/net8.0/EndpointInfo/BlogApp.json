            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CategoryColorsNullable": {
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5,
          null
        ],
        "type": "integer",
        "format": "int32",
        "nullable": true
      },
      "Comment": {
        "type": "object",
